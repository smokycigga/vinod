<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pending Approvals</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        body { background: #eef3f9; }
        .pending-container { max-width: 700px; margin: 40px auto; background: #fdfbf4; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); padding: 30px; }
        h2 { text-align: center; margin-bottom: 30px; }
        .pending-list { margin-top: 20px; }
        .pending-card { border: 1px solid #eee; border-radius: 8px; padding: 20px; margin-bottom: 18px; background: #f7f2dc; }
        .pending-card strong { color: #2c3e50; }
        .pending-card form { display: inline; }
        .btn-approve { background: #27ae60; color: #fdfbf4; border: none; padding: 8px 18px; border-radius: 6px; font-weight: 600; cursor: pointer; margin-left: 10px; }
        .btn-approve:hover { background: #219150; }
        .no-pending { text-align: center; color: #888; margin-top: 40px; }
    </style>
</head>
<body>
    <div class="pending-container">
        <h2>Pending Payment Approvals</h2>
        <div class="pending-list">
            <% if (pending.length === 0) { %>
                <div class="no-pending">No pending payments.</div>
            <% } %>
            <% pending.forEach(function(sub) { %>
                <div class="pending-card">
                    <div><strong>User:</strong> <%= sub.user ? sub.user.email : 'N/A' %></div>
                    <div><strong>Plan:</strong> <%= sub.plan %></div>
                    <div><strong>UTR:</strong> <%= sub.payment.utr || 'N/A' %></div>
                    <form method="POST" action="/admin/approve">
                        <input type="hidden" name="subscriptionId" value="<%= sub._id %>">
                        <button class="btn-approve" type="submit">Approve</button>
                    </form>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html> 