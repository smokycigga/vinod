<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Professional CRM Dashboard 2024</title>
    <link rel="stylesheet" href="/dashboard.css">
    <script type="module" src="/vendor/ionicons/ionicons.esm.js"></script>
    <script nomodule src="/vendor/ionicons/ionicons.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
    <!-- Flatpickr (Custom DatePicker) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <!-- SweetAlert2 (Custom Modals/Dialogs) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.5/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.5/dist/sweetalert2.all.min.js"></script>
    <style>
        .icon-sm {
            font-size: 16px;
            width: 16px;
            height: 16px;
        }

        .icon-md {
            font-size: 20px;
            width: 20px;
            height: 20px;
        }

        .icon-lg {
            font-size: 24px;
            width: 24px;
            height: 24px;
        }

        .icon-xl {
            font-size: 32px;
            width: 32px;
            height: 32px;
        }

        ion-icon {
            vertical-align: middle;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>

<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <!-- Sidebar Navigation -->


        <nav class="sidebar-nav">
            <a href="#" onclick="showSection('dashboard')" class="nav-item active" data-section="dashboard"
                data-tooltip="Dashboard">
                <ion-icon name="analytics-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Dashboard</span>
            </a>
            <a href="#" onclick="showSection('leads')" class="nav-item sales-only" data-section="leads"
                data-tooltip="Leads">
                <ion-icon name="people-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Leads</span>
            </a>
            <a href="#" onclick="showSection('pipeline')" class="nav-item" data-section="pipeline"
                data-tooltip="Pipeline">
                <ion-icon name="funnel-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Pipeline</span>
            </a>
            <a href="#" onclick="showSection('tasks')" class="nav-item" data-section="tasks" data-tooltip="Tasks">
                <ion-icon name="checkbox-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Tasks</span>
            </a>
            <a href="#" onclick="showSection('communication')" class="nav-item" data-section="communication"
                data-tooltip="Communications">
                <ion-icon name="chatbubble-ellipses-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Communications</span>
            </a>
            <a href="#" onclick="showSection('analytics')" class="nav-item" data-section="analytics"
                data-tooltip="Analytics">
                <ion-icon name="stats-chart-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Analytics</span>
            </a>
            <a href="#" onclick="showSection('users')" class="nav-item superadmin-admin-only" data-section="users"
                data-tooltip="Users">
                <ion-icon name="person-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Users</span>
            </a>
            <a href="#" onclick="showSection('settings')" class="nav-item" data-section="settings"
                data-tooltip="Settings">
                <ion-icon name="settings-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Settings</span>
            </a>
            <a href="#" onclick="showSection('activity-logs')" class="nav-item" data-section="activity-logs"
                data-tooltip="Activity Logs">
                <ion-icon name="time-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Activity Logs</span>
            </a>
            <a href="#" onclick="showSection('import-export')" class="nav-item" data-section="import-export"
                data-tooltip="Import/Export">
                <ion-icon name="swap-horizontal-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Import/Export</span>
            </a>
            <a href="#" onclick="showSection('invoices')" class="nav-item" data-section="invoices"
                data-tooltip="Invoices">
                <ion-icon name="document-text-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Invoices</span>
            </a>
            <a href="#" onclick="showSection('clients')" class="nav-item exclude-client" data-section="clients"
                data-tooltip="Clients">
                <ion-icon name="briefcase-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Clients</span>
            </a>
            <a href="#" onclick="showSection('agreements')" class="nav-item client-only" data-section="agreements"
                data-tooltip="My Agreements" style="display: none;">
                <ion-icon name="document-text-outline" class="icon-md"></ion-icon>
                <span class="nav-text">My Agreements</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <button class="btn-logout" onclick="logout()">
                <ion-icon name="log-out-outline" class="icon-md"></ion-icon>
                <span class="nav-text">Logout</span>
            </button>
        </div>
    </aside>

    <!-- Sidebar overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- TOP NAVIGATION BAR -->
    <nav class="top-nav">
        <div class="top-nav-left">
            <button id="sidebarToggle" class="mobile-nav-toggle" onclick="toggleSidebar()" aria-label="Toggle sidebar"
                title="Toggle sidebar">
                <ion-icon name="menu-outline" class="icon-md"></ion-icon>
            </button>
            <div class="logo">
                <ion-icon name="business" class="icon-lg"></ion-icon>
                <span class="logo-text">CRM System</span>
            </div>
        </div>
        <!-- Navigation links moved to side panel -->
        <div class="top-nav-center"></div>
        <div class="top-nav-right">
            <div class="top-nav-search">
                <ion-icon name="search-outline" class="icon-md"></ion-icon>
                <input type="text" placeholder="Search leads, tasks..." id="globalSearch">
            </div>
            <button class="top-nav-btn" onclick="showNotifications()">
                <ion-icon name="notifications-outline" class="icon-md"></ion-icon>
                <span class="notification-badge" id="notificationBadge">3</span>
            </button>
            <div class="top-nav-profile" onclick="showSection('settings')">
                <div class="top-nav-avatar"><ion-icon name="person-circle" class="icon-lg"></ion-icon></div>
                <div class="top-nav-user-info">
                    <div id="currentUserName" class="top-nav-user-name">Admin User</div>
                    <div id="currentUserRole" class="top-nav-user-role">Admin</div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content (NO sidebar margin since top nav is used) -->
    <div class="main-content top-nav-layout">
        <!-- old header hidden, title shown via greeting below -->

        <!-- Dashboard Section -->
        <section id="dashboard-section" class="content-section active">
            <!-- Greeting Header -->
            <div class="greeting-header">
                <div class="greeting-text">
                    <h1 id="greetingTitle">Good morning, <span id="greetingName">Samal</span>! <ion-icon
                            name="sunny-outline" class="icon-sm" style="color:#f59e0b;"></ion-icon> Ready to crush
                        today's goals?</h1>
                    <p>Here's what's happening in your business right now.</p>
                </div>
                <button class="btn btn-primary" onclick="refreshDashboard()">
                    <ion-icon name="refresh-outline" class="icon-sm"></ion-icon> Update
                </button>
            </div>

            <!-- 3-Column Dashboard Grid -->
            <div class="dash-three-col">
                <!-- LEFT: Lead Analytics Chart Card -->
                <div class="dash-card dash-card-chart">
                    <div class="dash-card-header">
                        <h3><ion-icon name="stats-chart-outline" class="icon-md"></ion-icon> Lead Analytics</h3>
                        <div class="dash-card-actions">
                            <select id="leadChartPeriod" class="chart-filter-select"
                                onchange="updateLeadAnalyticsChart()">
                                <option value="week">This Week</option>
                                <option value="month">This Month</option>
                                <option value="year">This Year</option>
                            </select>
                            <button class="icon-btn" onclick="updateLeadAnalyticsChart()" title="Refresh Data">
                                <ion-icon name="refresh-outline" class="icon-sm"></ion-icon>
                            </button>
                            <button class="icon-btn" onclick="exportLeadChart()" title="Export PNG">
                                <ion-icon name="download-outline" class="icon-sm"></ion-icon>
                            </button>
                        </div>
                    </div>
                    <div class="lead-chart-area">
                        <div id="chartLoadingOverlay" class="chart-loading-overlay">
                            <div class="spinner"></div>
                        </div>
                        <div id="chartEmptyState" class="chart-empty-state" style="display: none;">
                            <ion-icon name="bar-chart-outline" class="icon-xl"></ion-icon>
                            <p>No leads found for this period</p>
                            <button class="btn btn-primary btn-sm" onclick="openAddLeadModal()">Add Your First
                                Lead</button>
                        </div>
                        <canvas id="leadAnalyticsChart"></canvas>
                    </div>
                    <div class="chart-stats-row">
                        <div class="chart-stat">
                            <span class="chart-stat-val" id="totalLeads">0</span>
                            <span class="chart-stat-lbl">Total Leads</span>
                        </div>
                        <div class="chart-stat">
                            <span class="chart-stat-val trend-up" id="leadTrend">+0%</span>
                            <span class="chart-stat-lbl">Trend</span>
                        </div>
                        <div class="chart-stat">
                            <span class="chart-stat-val" id="bestDay">None</span>
                            <span class="chart-stat-lbl">Best Day</span>
                        </div>
                        <div class="chart-stat">
                            <span class="chart-stat-val" id="avgLeads">0</span>
                            <span class="chart-stat-lbl">Avg/Day</span>
                        </div>
                    </div>
                </div>

                <!-- MIDDLE: 2x2 Pastel Metric Cards -->
                <div class="dash-metrics-grid">
                    <div class="metric-card metric-orange">
                        <div class="metric-icon"><ion-icon name="people-outline" class="icon-xl"></ion-icon></div>
                        <div class="metric-value" id="totalLeadsMetric">0</div>
                        <div class="metric-label">Your Leads <span class="stat-hint">(let's grow this!)</span></div>
                    </div>
                    <div class="metric-card metric-green">
                        <div class="metric-icon"><ion-icon name="checkmark-circle-outline" class="icon-xl"></ion-icon>
                        </div>
                        <div class="metric-value" id="closedDealsMetric">0</div>
                        <div class="metric-label">Closed Deals <span class="stat-hint">(building momentum...)</span>
                        </div>
                    </div>
                    <div class="metric-card metric-purple">
                        <div class="metric-icon"><ion-icon name="time-outline" class="icon-xl"></ion-icon></div>
                        <div class="metric-value" id="pendingTasks">0</div>
                        <div class="metric-label">Pending Tasks</div>
                    </div>
                    <div class="metric-card metric-blue">
                        <div class="metric-icon"><ion-icon name="pie-chart-outline" class="icon-xl"></ion-icon></div>
                        <div class="metric-value" id="conversionRate">—</div>
                        <div class="metric-label">Conversion</div>
                    </div>
                </div>

                <!-- RIGHT: Quick Actions Card -->
                <div class="dash-card dash-card-actions">
                    <div class="dash-card-header">
                        <h3><ion-icon name="flash-outline" class="icon-sm"></ion-icon> Quick Actions</h3>
                    </div>
                    <div class="quick-actions-list">
                        <button class="quick-action-btn" onclick="openAddLeadModal()">
                            <div class="qa-icon qa-blue"><ion-icon name="person-add-outline"></ion-icon></div>
                            <span>Bring in a Lead &nbsp;<ion-icon name="sparkles-outline"
                                    style="font-size:12px;vertical-align:middle;color:#C9963A;"></ion-icon></span>
                            <ion-icon name="chevron-forward-outline" class="qa-arrow"></ion-icon>
                        </button>
                        <button class="quick-action-btn" onclick="showSection('tasks')">
                            <div class="qa-icon qa-orange"><ion-icon name="checkbox-outline"></ion-icon></div>
                            <span>Create Task</span>
                            <ion-icon name="chevron-forward-outline" class="qa-arrow"></ion-icon>
                        </button>
                        <button class="quick-action-btn" onclick="showSection('pipeline')">
                            <div class="qa-icon qa-green"><ion-icon name="funnel-outline"></ion-icon></div>
                            <span>View Pipeline</span>
                            <ion-icon name="chevron-forward-outline" class="qa-arrow"></ion-icon>
                        </button>
                        <button class="quick-action-btn" onclick="showSection('analytics')">
                            <div class="qa-icon qa-purple"><ion-icon name="stats-chart-outline"></ion-icon></div>
                            <span>Reports</span>
                            <ion-icon name="chevron-forward-outline" class="qa-arrow"></ion-icon>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Bottom Section: Recent Activity & Tasks as unified table -->
            <div class="dash-bottom-section">
                <div class="dash-card dash-card-wide">
                    <div class="dash-card-header">
                        <h3><ion-icon name="time-outline" class="icon-sm"></ion-icon> Recent Activity <ion-icon
                                name="sparkles-outline" class="icon-sm"></ion-icon></h3>
                        <a href="#" class="view-all-link" onclick="showSection('activity-logs')">View all <ion-icon
                                name="arrow-forward-outline" class="icon-sm"></ion-icon></a>
                    </div>
                    <div id="recentActivity" class="activity-list"></div>
                </div>
                <div class="dash-card dash-card-wide">
                    <div class="dash-card-header">
                        <h3><ion-icon name="calendar-outline" class="icon-sm"></ion-icon> Your Upcoming Tasks <ion-icon
                                name="document-text-outline" class="icon-sm"></ion-icon></h3>
                        <a href="#" class="view-all-link" onclick="showSection('tasks')">View all <ion-icon
                                name="arrow-forward-outline" class="icon-sm"></ion-icon></a>
                    </div>
                    <div id="upcomingTasks" class="task-list"></div>
                </div>
            </div>
        </section>

        <!-- Leads Section -->
        <section id="leads-section" class="content-section">
            <div class="section-header">
                <h2>Potential Customers</h2>
                <div class="section-actions">
                    <button class="btn btn-primary" onclick="openAddLeadModal()">
                        <ion-icon name="add-outline" class="icon-sm"></ion-icon> Add a Lead
                    </button>
                </div>
            </div>

            <div class="task-filters" id="leadsAssignedFilterBar">
                <button class="filter-btn active" onclick="filterLeadsByAssignment('all')">All</button>
                <button class="filter-btn" onclick="filterLeadsByAssignment('assigned')">Assigned</button>
                <button class="filter-btn" onclick="filterLeadsByAssignment('not-assigned')">Not Assigned</button>
            </div>

            <div class="table-container">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Company Name</th>
                            <th>Contact Person</th>
                            <th>Designation</th>
                            <th>Email</th>
                            <th>Mobile</th>
                            <th>Assigned To</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="leadsTableBody"></tbody>
                </table>
                <div id="leadsEmptyState" class="empty-state"
                    style="display: none; padding: 40px; text-align: center; color: #64748B;">
                    <ion-icon name="people-outline"
                        style="font-size: 48px; margin-bottom: 10px; opacity: 0.5;"></ion-icon>
                    <p>No potential customers found matching your criteria</p>
                </div>
                <div class="pagination-container" style="display: none;">
                    <button id="prevPageBtn" class="btn-page" onclick="prevLeadPage()" title="Previous page">
                        <ion-icon name="chevron-back-outline"></ion-icon>
                    </button>
                    <div id="leadPageNumbers" class="page-numbers"></div>
                    <button id="nextPageBtn" class="btn-page" onclick="nextLeadPage()" title="Next page">
                        <ion-icon name="chevron-forward-outline"></ion-icon>
                    </button>
                </div>
            </div>
        </section>

        <!-- Clients Section -->
        <section id="clients-section" class="content-section">
            <div class="section-header">
                <h2>Clients</h2>
                <div class="section-actions">
                    <span id="clientsCount" style="font-size:13px;color:var(--gray-500);margin-right:12px;"></span>
                </div>
            </div>
            <div class="table-container">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Company Name</th>
                            <th>Contact Person</th>
                            <th>Designation</th>
                            <th>Email</th>
                            <th>Mobile</th>
                            <th>Assigned To</th>
                            <th>Status Details</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="clientsTableBody"></tbody>
                </table>
                <div id="clientsEmptyState" class="empty-state"
                    style="display: none; padding: 40px; text-align: center; color: #64748B;">
                    <ion-icon name="briefcase-outline"
                        style="font-size: 48px; margin-bottom: 10px; opacity: 0.5;"></ion-icon>
                    <p>No clients yet. Leads marked as <strong>Agreement Signed</strong> with an uploaded agreement will appear here.</p>
                </div>
            </div>
        </section>

        <!-- Agreements Section (Client Only) -->
        <section id="agreements-section" class="content-section">
            <div class="section-header">
                <h2>My Agreements</h2>
            </div>
            <div class="table-container">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Invoice Number</th>
                            <th>Date</th>
                            <th>Agreement File</th>
                            <th>Download</th>
                        </tr>
                    </thead>
                    <tbody id="agreementsTableBody"></tbody>
                </table>
                <div id="agreementsEmptyState" class="empty-state"
                    style="display: none; padding: 40px; text-align: center; color: #64748B;">
                    <ion-icon name="document-text-outline"
                        style="font-size: 48px; margin-bottom: 10px; opacity: 0.5;"></ion-icon>
                    <p>No agreements found for your account.</p>
                </div>
            </div>
        </section>

        <!-- Pipeline Section -->
        <section id="pipeline-section" class="content-section">
            <div class="section-header">
                <h2>Pipeline</h2>
                <button class="btn btn-secondary" onclick="openPipelineSettings()">
                    <ion-icon name="settings-outline" class="icon-sm"></ion-icon> Manage Pipeline
                </button>
            </div>
            <div class="pipeline-kanban" id="pipelineKanban"></div>
        </section>

        <!-- Tasks Section -->
        <section id="tasks-section" class="content-section">
            <div class="section-header">
                <h2>Tasks & Reminders</h2>
                <button class="btn btn-primary" onclick="openAddTaskModal()">
                    <ion-icon name="add-outline" class="icon-sm"></ion-icon> Add Task
                </button>
            </div>

            <div class="task-filters">
                <button class="filter-btn active" onclick="filterTasks('all')">All</button>
                <button class="filter-btn" onclick="filterTasks('pending')">Pending</button>
                <button class="filter-btn" onclick="filterTasks('in-progress')">In Progress</button>
                <button class="filter-btn" onclick="filterTasks('completed')">Completed</button>
                <button class="filter-btn" onclick="filterTasks('overdue')">Overdue</button>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Action</th>
                            <th>Lead</th>
                            <th>Assigned To</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tasksTableBody"></tbody>
                </table>
            </div>
        </section>

        <!-- Communication Section -->
        <section id="communication-section" class="content-section">
            <div class="section-header">
                <h2>Communication Tracking</h2>
                <div class="section-actions">
                    <select id="commLeadSelect"
                        style="padding: 8px; border: 1px solid #ddd; border-radius: 6px; margin-right: 12px; min-width: 200px;">
                        <option value="">Select Lead...</option>
                    </select>
                    <button class="btn btn-success" onclick="openSendEmailModalWithLeadSelect()">
                        <ion-icon name="mail-outline" class="icon-sm"></ion-icon> Send Email
                    </button>
                    <button class="btn btn-success" onclick="openSendWhatsAppModalWithLeadSelect()">
                        <ion-icon name="logo-whatsapp" class="icon-sm"></ion-icon> Send WhatsApp
                    </button>
                    <button class="btn btn-secondary" onclick="openLogCallModalWithLeadSelect()">
                        <ion-icon name="call-outline" class="icon-sm"></ion-icon> Log Call
                    </button>
                    <button class="btn btn-secondary" onclick="openLogMeetingModalWithLeadSelect()">
                        <ion-icon name="people-outline" class="icon-sm"></ion-icon> Log Meeting
                    </button>
                </div>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Lead</th>
                            <th>Subject/Description</th>
                            <th>Direction</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="communicationTableBody"></tbody>
                </table>
            </div>
        </section>

        <!-- Analytics Section -->
        <section id="analytics-section" class="content-section">
            <div class="section-header">
                <h2>Analytics & Reports</h2>
                <button class="btn btn-secondary" onclick="exportAnalytics()">
                    <ion-icon name="download-outline" class="icon-sm"></ion-icon> Export Report
                </button>
            </div>

            <div class="analytics-grid">
                <div class="analytics-card">
                    <h3><ion-icon name="pie-chart-outline" class="icon-sm"></ion-icon> Lead Conversion Rate</h3>
                    <div class="chart-placeholder" id="conversionChart">
                        <div class="chart-value">32.5%</div>
                        <div class="chart-label">Conversion Rate</div>
                    </div>
                </div>
                <div class="analytics-card">
                    <h3><ion-icon name="bar-chart-outline" class="icon-sm"></ion-icon> Pipeline Analysis</h3>
                    <div class="chart-placeholder" id="pipelineChart"></div>
                </div>
                <div class="analytics-card">
                    <h3><ion-icon name="people-outline" class="icon-sm"></ion-icon> Team Performance</h3>
                    <div class="chart-placeholder" id="teamChart"></div>
                </div>
            </div>
        </section>

        <!-- User Management Section (Admin and Manager) -->
        <section id="users-section" class="content-section admin-manager-only">
            <div class="section-header">
                <h2>User Management</h2>
                <button class="btn btn-primary" onclick="openAddUserModal()">
                    <ion-icon name="person-add-outline" class="icon-sm"></ion-icon> Add User
                </button>
            </div>

            <div class="table-container">
                <table class="user-management-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Last Login</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody"></tbody>
                </table>
            </div>
        </section>

        <!-- Settings Section -->
        <section id="settings-section" class="content-section">
            <div class="section-header">
                <h2>Settings</h2>
            </div>

            <div class="settings-tabs">
                <button class="tab-btn active" onclick="showSettingsTab('profile')">
                    <ion-icon name="person-outline" class="icon-sm"></ion-icon> Profile
                </button>
                <button class="tab-btn" onclick="showSettingsTab('company')">
                    <ion-icon name="business-outline" class="icon-sm"></ion-icon> Company
                </button>
                <button class="tab-btn" onclick="showSettingsTab('email')">
                    <ion-icon name="mail-outline" class="icon-sm"></ion-icon> Email Config
                </button>
                <button class="tab-btn" onclick="showSettingsTab('whatsapp')">
