                        placeholder="Add resolution notes..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeEditOperationModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Ticket</button>
                </div>
            </form>
        </div>
    </div>

    <!-- View Operation Modal -->
    <div id="viewOperationModal" class="modal">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <h2>Operation Ticket Details</h2>
                <button class="modal-close" onclick="closeViewOperationModal()">&times;</button>
            </div>
            <div id="viewOperationContent" class="view-details"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeViewOperationModal()">Close</button>
                <button type="button" class="btn btn-primary" onclick="editOperationFromView()">Edit Ticket</button>
            </div>
        </div>
    </div>

    <!-- Pipeline Settings Modal -->
    <div id="pipelineSettingsModal" class="modal">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <h2>Manage Pipeline Stages</h2>
                <button class="modal-close" onclick="closePipelineSettings()">&times;</button>
            </div>
            <div class="pipeline-manager">
                <button class="btn btn-primary mb-20" onclick="addPipelineStage()">
                    <ion-icon name="add-outline" class="icon-sm"></ion-icon> Add Stage
                </button>
                <div id="pipelineStagesList" class="pipeline-stages-list"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closePipelineSettings()">Close</button>
                <button class="btn btn-primary" onclick="savePipelineSettings()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- Operations Pipeline Settings Modal -->
    <div id="operationsPipelineSettingsModal" class="modal">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <h2>Manage Operations Pipeline Stages</h2>
                <button class="modal-close" onclick="closeOperationsPipelineSettings()">&times;</button>
            </div>
            <div class="pipeline-manager">
                <button class="btn btn-primary mb-20" onclick="addOperationsStage()">
                    <ion-icon name="add-outline" class="icon-sm"></ion-icon> Add Stage
                </button>
                <div id="operationsPipelineStagesList" class="pipeline-stages-list"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeOperationsPipelineSettings()">Close</button>
                <button class="btn btn-primary" onclick="saveOperationsPipelineSettings()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- View Task Modal -->
    <div id="viewTaskModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Task Details</h2>
                <button class="modal-close" onclick="closeViewTaskModal()">&times;</button>
            </div>
            <div id="viewTaskContent" class="lead-details-content"></div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeViewTaskModal()">Close</button>
            </div>
        </div>
    </div>

    <!-- Edit Task Modal -->
    <div id="editTaskModal" class="modal">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <h2>Edit Task</h2>
                <button class="modal-close" onclick="closeEditTaskModal()">&times;</button>
            </div>
            <form id="editTaskForm" onsubmit="handleEditTask(event)">
                <input type="hidden" id="editTaskId">
                <div class="form-group">
                    <label>Action Type *</label>
                    <select id="editTaskAction" name="action" required>
                        <option value="">Select Action</option>
                        <option value="message">📩 Normal Message</option>
                        <option value="urgent-message">⚠️ Urgent Message</option>
                        <option value="emergency-message">🚨 Emergency Message</option>
                        <option value="call">Call</option>
                        <option value="email">Email</option>
                        <option value="meeting">Meeting</option>
                        <option value="follow-up">Follow-up</option>
                        <option value="demo">Demo</option>
                        <option value="site-visit">Site Visit</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Remarks</label>
                    <textarea id="editTaskRemarks" name="remarks" rows="2" placeholder="Additional notes..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Due Date *</label>
                        <input type="datetime-local" id="editTaskDueDate" name="dueDate" required>
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select id="editTaskStatus" name="status">
                            <option value="pending">Pending</option>
                            <option value="in-progress">In Progress</option>
                            <option value="completed">Completed</option>
                            <option value="cancelled">Cancelled</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Assigned To *</label>
                    <select id="editTaskAssignedTo" name="assignedTo" required>
                        <option value="">Select User</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Status Details / Communication History</label>
                    <div id="editTaskStatusUpdatesDisplay" class="status-updates-container"></div>
                    <textarea name="newStatusUpdate" rows="2" placeholder="Add new update/message here..."></textarea>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea id="editTaskNotes" name="notes" rows="2"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeEditTaskModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Send Email Modal -->
    <div id="sendEmailModal" class="modal">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <h2>Send Email</h2>
                <button class="modal-close" onclick="closeSendEmailModal()">&times;</button>
            </div>
            <form id="sendEmailForm" onsubmit="handleSendEmail(event)">
                <input type="hidden" id="emailLeadId">
                <div class="form-group">
                    <label>To *</label>
                    <input type="email" id="emailTo" name="to" required>
                </div>
                <div class="form-group">
                    <label>CC</label>
                    <input type="text" id="emailCc" name="cc" placeholder="Separate multiple emails with commas">
                </div>
                <div class="form-group">
                    <label>Subject *</label>
                    <input type="text" name="subject" required>
                </div>
                <div class="form-group">
                    <label>Message *</label>
                    <textarea name="content" rows="4" required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeSendEmailModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary"><ion-icon name="send-outline"
                            class="icon-sm"></ion-icon> Send Email</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Send WhatsApp Modal -->
    <div id="sendWhatsAppModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Send WhatsApp Message</h2>
                <button class="modal-close" onclick="closeSendWhatsAppModal()">&times;</button>
            </div>
            <form id="sendWhatsAppForm" onsubmit="handleSendWhatsApp(event)">
                <input type="hidden" id="whatsappLeadId">
                <div class="form-group">
                    <label>Phone Number *</label>
                    <input type="tel" id="whatsappTo" name="to" required placeholder="+1234567890">
                </div>
                <div class="form-group">
                    <label>Message *</label>
                    <textarea name="content" rows="3" required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeSendWhatsAppModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary"><ion-icon name="logo-whatsapp"
                            class="icon-sm"></ion-icon> Send Message</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Log Call Modal -->
    <div id="logCallModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Log Call</h2>
                <button class="modal-close" onclick="closeLogCallModal()">&times;</button>
            </div>
            <form id="logCallForm" onsubmit="handleLogCall(event)">
                <input type="hidden" id="callLeadId">
                <div class="form-group">
                    <label>Phone Number *</label>
                    <input type="tel" id="callTo" name="to" required placeholder="+1234567890">
                </div>
                <div class="form-group">
                    <label>Call Duration (minutes)</label>
                    <input type="number" name="duration" min="0" step="1" value="0">
                </div>
                <div class="form-group">
                    <label>Call Notes *</label>
                    <textarea name="content" rows="3" required placeholder="Summary of the call..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeLogCallModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary"><ion-icon name="call-outline"
                            class="icon-sm"></ion-icon> Log Call</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Log Meeting Modal -->
    <div id="logMeetingModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Log Meeting</h2>
                <button class="modal-close" onclick="closeLogMeetingModal()">&times;</button>
            </div>
            <form id="logMeetingForm" onsubmit="handleLogMeeting(event)">
                <input type="hidden" id="meetingLeadId">
                <div class="form-group">
                    <label>Meeting Duration (minutes)</label>
                    <input type="number" name="duration" min="0" step="1" value="30">
                </div>
                <div class="form-group">
                    <label>Attendees</label>
                    <input type="text" name="attendees" placeholder="John Doe, Jane Smith">
                </div>
                <div class="form-group">
                    <label>Meeting Notes *</label>
                    <textarea name="content" rows="3" required
                        placeholder="Meeting summary, key points discussed, action items..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeLogMeetingModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary"><ion-icon name="calendar-outline"
                            class="icon-sm"></ion-icon> Log
                        Meeting</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Upload File Modal -->
    <div id="uploadFileModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Upload File</h2>
                <button class="modal-close" onclick="closeUploadFileModal()">&times;</button>
            </div>
            <form id="uploadFileForm" onsubmit="handleUploadFile(event)">
                <input type="hidden" id="uploadLeadId">
                <div class="form-group">
                    <label>Select File *</label>
                    <input type="file" id="fileInput" name="file" required>
                    <small>Supported: PDF, DOC, DOCX, XLS, XLSX, PNG, JPG (Max 10MB)</small>
                </div>
                <div class="form-group">
                    <label>File Description</label>
                    <input type="text" name="description" placeholder="e.g., Proposal, Contract, Invoice">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeUploadFileModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary"><ion-icon name="cloud-upload-outline"
                            class="icon-sm"></ion-icon> Upload</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add/Edit User Modal -->
    <div id="addUserModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="userModalTitle">Add New User</h2>
                <button class="modal-close" onclick="closeAddUserModal()">&times;</button>
            </div>
            <form id="addUserForm" onsubmit="handleAddUser(event)">
                <input type="hidden" id="editUserId">
                <div class="form-group">
                    <label>Full Name *</label>
                    <input type="text" name="fullName" id="userFullName" required placeholder="John Doe">
                </div>
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" name="email" id="userEmail" required placeholder="john@company.com">
                </div>
                <div class="form-group">
                    <label>Password *</label>
                    <input type="password" name="password" id="userPassword" required minlength="6"
                        placeholder="Minimum 6 characters">
                    <small id="passwordHint">Leave blank to keep current password when editing</small>
                </div>
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" id="userUsername" placeholder="johndoe">
                </div>
                <div class="form-group">
                    <label>Phone</label>
                    <input type="tel" name="phone" id="userPhone" placeholder="+1234567890">
                </div>
                <div class="form-group">
                    <label>Role *</label>
                    <select name="role" id="userRole" required>
                        <option value="">Select Role</option>
                        <option value="staff">Staff</option>
                        <option value="manager">Manager</option>
                        <option value="admin">Admin</option>
                        <option value="superadmin" class="superadmin-only">Super Admin</option>
                    </select>
                    <small>
                        <strong>Staff:</strong> Can update assigned leads (status & remarks only)<br>
                        <strong>Manager:</strong> Team management & lead creation for own team<br>
                        <strong>Admin:</strong> Department management, role assignment & reporting<br>
                        <strong>Super Admin:</strong> Full system access including user creation & role assignment
                    </small>
                </div>
                <div class="form-group" id="departmentSelectGroup" style="display: none;">
                    <label>Department <span class="required">*</span></label>
                    <select name="department" id="userDepartment">
                        <option value="">Select Department</option>
                        <option value="sales">Sales</option>
                        <option value="operations">Operations</option>
                    </select>
                    <small>Select the department for this user</small>
                </div>
                <div class="form-group" id="managerSelectGroup" style="display: none;">
                    <label>Assign to Manager</label>
                    <select name="managerId" id="userManagerId">
                        <option value="">No Manager</option>
                    </select>
                    <small>Select a manager to assign this user to their team</small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeAddUserModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary"><ion-icon name="save-outline"
                            class="icon-sm"></ion-icon> Save User</button>
                </div>
            </form>
        </div>
    </div>

    <!-- View User Modal -->
    <div id="viewUserModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>User Details</h2>
                <button class="modal-close" onclick="closeViewUserModal()">&times;</button>
            </div>
            <div id="viewUserContent"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeViewUserModal()">Close</button>
                <button type="button" class="btn btn-primary" onclick="editUserFromView()"><ion-icon
                        name="create-outline" class="icon-sm"></ion-icon>
                    Edit</button>
            </div>
        </div>
    </div>

    <script src="/dashboard.js?v=<%= Date.now() %>"></script>
    <script src="/lead-analytics.js"></script>
    <script>
        // Initialize greeting
        if (typeof updateGreeting === 'function') updateGreeting();

        // Sync greeting name with logged-in user name
        const _origSetUser = window.setCurrentUser;
        window.setCurrentUser = function (user) {
            if (_origSetUser) _origSetUser(user);
            const nameEl = document.getElementById('greetingName');
            if (nameEl && user && user.name) nameEl.textContent = user.name;
            if (typeof updateGreeting === 'function') updateGreeting();
        };

        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('loginPassword');
            const icon = document.querySelector('.password-toggle');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.setAttribute('name', 'eye-outline');
            } else {
                passwordInput.type = 'password';
                icon.setAttribute('name', 'eye-off-outline');
            }
        }
    </script>
</body>

</html>
