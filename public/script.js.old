function removeContact(type, index) {
    let containerId;
    let count;
    
    switch(type) {
        case 'email':
            containerId = 'emailsContainer';
            count = emailCount;
            break;
        case 'phone':
            containerId = 'phonesContainer';
            count = phoneCount;
            break;
        case 'editEmail':
            containerId = 'editEmailsContainer';
            count = editEmailCount;
            break;
        case 'editPhone':
            containerId = 'editPhonesContainer';
            count = editPhoneCount;
            break;
    }
    
    const container = document.getElementById(containerId);
    const items = container.querySelectorAll('.contact-item');
    
    if (items.length > 1) {
        items[index].remove();
        updateRemoveButtons(containerId);
    }
}

function updateRemoveButtons(containerId) {
    const container = document.getElementById(containerId);
    const items = container.querySelectorAll('.contact-item');
    const removeButtons = container.querySelectorAll('.btn-remove-contact');
    
    // Show remove button only if there's more than one item
    removeButtons.forEach((button, index) => {
        if (items.length > 1) {
            button.style.display = 'block';
        } else {
            button.style.display = 'none';
        }
    });
}

// Reset contact counters when modals are opened
function resetContactCounters() {
    emailCount = 1;
    phoneCount = 1;
    editEmailCount = 1;
    editPhoneCount = 1;
}

// --- SUBSCRIPTION MODAL LOGIC ---
function openSubscriptionModal() {
    document.getElementById('subscriptionModal').style.display = 'block';
    document.getElementById('subscriptionStepPlans').style.display = '';
    document.getElementById('subscriptionStepQR').style.display = 'none';
    document.getElementById('subscriptionStepPending').style.display = 'none';
    loadPlans();
}
function closeSubscriptionModal() {
    document.getElementById('subscriptionModal').style.display = 'none';
}
async function loadPlans() {
    const res = await fetch(SUBS_API_URL + '/plans', { headers: { Authorization: 'Bearer ' + authToken } });
    const plans = await res.json();
    const plansContainer = document.getElementById('plansContainer');
    plansContainer.innerHTML = plans.map(plan => `
        <div class="plan-card">
            <h4>${plan.label}</h4>
            <p>₹${plan.price} / ${plan.label.toLowerCase()}</p>
            <button class="btn btn-primary" onclick="selectPlan('${plan.plan}')">Select</button>
        </div>
    `).join('');
}
async function selectPlan(plan) {
    const res = await fetch(SUBS_API_URL + '/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + authToken },
        body: JSON.stringify({ plan })
    });
    const data = await res.json();
    if (data.qrUrl) {
        currentSubscriptionId = data.subscriptionId;
        document.getElementById('subscriptionStepPlans').style.display = 'none';
        document.getElementById('subscriptionStepQR').style.display = '';
        document.getElementById('paymentQR').src = data.qrUrl;
        // Add Pay Now button
        const payNowBtnId = 'payNowBtn';
        let payNowBtn = document.getElementById(payNowBtnId);
        if (!payNowBtn) {
            payNowBtn = document.createElement('a');
            payNowBtn.id = payNowBtnId;
            payNowBtn.className = 'btn btn-primary';
            payNowBtn.innerText = 'Pay Now';
            payNowBtn.style.display = 'block';
            payNowBtn.style.margin = '16px 0';
            // Insert above UTR input
            const qrStep = document.getElementById('subscriptionStepQR');
            qrStep.insertBefore(payNowBtn, qrStep.querySelector('.form-group'));
        }
        // Set amount and returnUrl
        let amount = 100; // default fallback
        if (plan === 'monthly') amount = 1;
        if (plan === 'yearly') amount = 8629;
        // Include userId and plan in returnUrl for backend activation
        let userId = currentUser && currentUser._id ? currentUser._id : '';
        // Use URLSearchParams to build the query string safely
        const params = new URLSearchParams({ userId, plan });
        const returnUrl = encodeURIComponent(`https://crm.gavenue.io/payment-success?${params.toString()}`);
        payNowBtn.href = `https://gavenue.in/checkout?amount=${amount}&returnUrl=${returnUrl}`;
        payNowBtn.target = '_blank';
    }
}
async function submitUTR() {
    const utr = document.getElementById('utrInput').value;
    if (!utr) return showNotification('Please enter UTR/Transaction ID', 'error');
    const res = await fetch(SUBS_API_URL + '/utr', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + authToken },
        body: JSON.stringify({ subscriptionId: currentSubscriptionId, utr })
    });
    if (res.ok) {
        document.getElementById('subscriptionStepQR').style.display = 'none';
        document.getElementById('subscriptionStepPending').style.display = '';
        fetchUserProfile();
    } else {
        showNotification('Failed to submit UTR', 'error');
    }
}

// --- ADMIN APPROVAL LOGIC ---
function openAdminModal() {
    document.getElementById('adminModal').style.display = 'block';
    loadPendingApprovals();
}
function closeAdminModal() {
    document.getElementById('adminModal').style.display = 'none';
}
async function loadPendingApprovals() {
    const res = await fetch(SUBS_API_URL + '/admin/pending', { headers: { Authorization: 'Bearer ' + authToken } });
    const approvals = await res.json();
    const container = document.getElementById('pendingApprovalsContainer');
    container.innerHTML = approvals.map(sub => `
        <div class="approval-card">
            <p><b>User:</b> ${sub.user.email}</p>
            <p><b>Plan:</b> ${sub.plan}</p>
            <p><b>UTR:</b> ${sub.payment.utr || 'N/A'}</p>
            <button class="btn btn-success" onclick="approveSubscription('${sub._id}')">Approve</button>
        </div>
    `).join('');
}
async function approveSubscription(subscriptionId) {
    const res = await fetch(SUBS_API_URL + '/admin/approve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + authToken },
        body: JSON.stringify({ subscriptionId })
    });
    if (res.ok) {
        showNotification('Subscription approved', 'success');
        loadPendingApprovals();
    } else {
        showNotification('Failed to approve', 'error');
    }
}

// Fetch user profile and subscription
async function fetchUserProfile() {
    try {
        const res = await fetch(SUBS_API_URL + '/status', {
            headers: { Authorization: 'Bearer ' + authToken }
        });
        if (!res.ok) throw new Error('Not authenticated');
        const data = await res.json();
        userSubscription = data.subscription;
        currentUser = { _id: data._id, email: data.email };
        isAdmin = userSubscription && userSubscription.isAdmin;
        document.getElementById('logoutBtn').style.display = '';
        // Load API key when profile is fetched
        loadApiKey();
        // Optionally show admin button if isAdmin
        loadLeads(); // Load leads after successful profile fetch
    } catch {
        logout();
    }
}

// Login/Register logic
function openLoginModal() {
    document.getElementById('loginModal').style.display = 'block';
}
function closeLoginModal() {
    document.getElementById('loginModal').style.display = 'none';
}
function openRegisterModal() {
    closeLoginModal();
    document.getElementById('registerModal').style.display = 'block';
}
function closeRegisterModal() {
    document.getElementById('registerModal').style.display = 'none';
}
function logout() {
    localStorage.removeItem('authToken');
    authToken = null;
    currentUser = null;
    userSubscription = null;
    document.getElementById('logoutBtn').style.display = 'none';
    openLoginModal();
}

document.getElementById('loginForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const email = document.getElementById('loginEmail').value;
    const password = document.getElementById('loginPassword').value;
    try {
        const res = await fetch(AUTH_API_URL + '/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        const data = await res.json();
        if (res.ok && data.token) {
            authToken = data.token;
            localStorage.setItem('authToken', authToken);
            closeLoginModal();
            fetchUserProfile();
            loadLeads();
        } else {
            showNotification(data.message || 'Login failed', 'error');
        }
    } catch {
        showNotification('Login error', 'error');
    }
});

document.getElementById('registerForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const email = document.getElementById('registerEmail').value;
    const password = document.getElementById('registerPassword').value;
    try {
        const res = await fetch(AUTH_API_URL + '/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        const data = await res.json();
        if (res.ok) {
            closeRegisterModal();
            openLoginModal();
            showNotification('Registration successful. Please login.', 'success');
        } else {
            showNotification(data.message || 'Registration failed', 'error');
        }
    } catch {
        showNotification('Registration error', 'error');
    }
});

// Profile Modal Functions
function openProfileModal() {
    document.getElementById('profileModal').style.display = 'block';
    loadApiKey();
}

function closeProfileModal() {
    document.getElementById('profileModal').style.display = 'none';
}

async function loadApiKey() {
    try {
        const response = await fetch(AUTH_API_URL + '/api-key', {
            headers: {
                'Authorization': 'Bearer ' + authToken
            }
        });
        if (!response.ok) throw new Error('Failed to fetch API key');
        const data = await response.json();
        document.getElementById('apiKeyDisplay').value = data.apiKey;
        // Show API request limit message if trial and limit reached
        if (userSubscription && (userSubscription.plan === 'trial' || userSubscription.status === 'trial')) {
            let trialLeadMsg = '';
            if (typeof data.trialLeadTotal !== 'undefined') {
                trialLeadMsg += `<span style=\"color:#666;font-size:13px;\">Trial leads added: ${data.trialLeadTotal}/50</span><br>`;
            }
            if (typeof data.currentLeadCount !== 'undefined') {
                trialLeadMsg += `<span style=\"color:#666;font-size:13px;\">Current leads: ${data.currentLeadCount}/50</span><br>`;
            }
            if (typeof data.apiRequestCount !== 'undefined' && data.apiRequestCount >= 50) {
                document.getElementById('apiLimitMessage').innerHTML = trialLeadMsg + '<span style=\"color:#e74c3c;font-weight:bold;\">API request limit exhausted. Please take a subscription to continue.</span><br><button class=\"btn btn-primary\" style=\"margin-top:8px;\" onclick=\"openSubscriptionModal()\"><i class=\"fas fa-shopping-cart\"></i> Buy/Upgrade</button>';
            } else {
                document.getElementById('apiLimitMessage').innerHTML = trialLeadMsg;
            }
        } else {
            document.getElementById('apiLimitMessage').innerHTML = '';
        }
    } catch (error) {
        showNotification('Error loading API key', 'error');
    }
}

async function regenerateApiKey() {
    if (!confirm('Are you sure you want to regenerate your API key? This will invalidate your existing key.')) {
        return;
    }
    try {
        const response = await fetch(AUTH_API_URL + '/api-key/regenerate', {
            method: 'POST',
            headers: {
                'Authorization': 'Bearer ' + authToken
            }
        });
        if (!response.ok) throw new Error('Failed to regenerate API key');
        const data = await response.json();
        document.getElementById('apiKeyDisplay').value = data.apiKey;
        showNotification('API key regenerated successfully', 'success');
    } catch (error) {
        showNotification('Error regenerating API key', 'error');
    }
}

function copyApiKey() {
    const apiKeyInput = document.getElementById('apiKeyDisplay');
    apiKeyInput.select();
    document.execCommand('copy');
    showNotification('API key copied to clipboard', 'success');
} 